# sparkz.xyz — Environment Variables
# Copy to .env.local for local development
# Set on Vercel dashboard for production

# ── Public (exposed to browser + build) ────────────────────────────────────
# Base URL — used for OG image URLs and Farcaster Frame meta
NEXT_PUBLIC_BASE_URL=https://sparkz.xyz

# ── Server-only ─────────────────────────────────────────────────────────────
# Stripe secret key — activates card backing on /back
# Omit to run in waitlist mode (form collects email, no charge)
# STRIPE_SECRET_KEY=sk_live_...

# Resend API key — activates email confirmations for /back and /vetted
# Omit to skip email notifications (form still works)
# RESEND_API_KEY=re_...

# From address for Resend emails
# Default: sparkz@sparkz.xyz
# RESEND_FROM_EMAIL=sparkz@sparkz.xyz

# Notification email for new backing + vetting applications
# Default: zaalp99@gmail.com
# ZAO_NOTIFY_EMAIL=zaalp99@gmail.com

# Viniapp relay key — pre-shared secret for Viniapp → /api/advisor relay
# Set when Chris Dolinski is ready to connect Viniapp (Phase 2)
# Omit to leave /api/advisor open (POST still validates inputs + uses BYOK)
# VINIAPP_RELAY_KEY=any_secret_string
