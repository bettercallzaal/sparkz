# Sparkz env - copy to .env.local and fill. NEVER commit real values.

# --- Supabase (the Capsule store) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only, never sent to the browser

# --- Cheap LLM tier (Meme Engine drafting - the 3 responses) ---
# Use OpenRouter/Ollama, not a metered Claude path (see CLAUDE.md).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# --- Operator auth (gates the service-role write routes; fails closed if unset) ---
# The service client bypasses RLS, so the API routes do their own authz against this
# token (held in an httpOnly cookie via /api/admin/login). Single-operator for now;
# per-creator auth (Farcaster SIWF / wallet) lands later. Generate: openssl rand -hex 24
SPARKZ_ADMIN_TOKEN=

# --- Approval channels (redundant multi-channel; first-approve-wins) ---
# In-app approval is always on. Discord is wired but DARK until this is set:
# a webhook posts flagged signals + the 3 drafts + a click-through approve link.
DISCORD_WEBHOOK_URL=

# --- Wallet connect (Reown AppKit / WalletConnect) - makes mobile connect work ---
# Public projectId (free) from https://reown.com (Cloud). Safe as NEXT_PUBLIC.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# --- Empire Builder (non-token empire rail; empirebuilder.world) ---
# Read/resolve empires needs no key. Deploying a tokenless empire is MAINNET-LIVE
# on Base and needs the API key + an owner wallet to sign (EIP-191). 2 deploys/
# wallet/24h. Leave blank until you deliberately deploy.
EMPIRE_API_KEY=
# The owner/signer wallet private key for tokenless deploys (server-side signer).
# SECRET. Only set when wiring live deploys - decide signer strategy first.
EMPIRE_OWNER_PRIVATE_KEY=

# --- Brand audit (OSS-repo Capsule import) ---
# Optional: raises the GitHub API rate limit and reaches private ZAO repos.
GITHUB_TOKEN=

# --- Farcaster (FEF - Farcaster Eats First; feed + identity + notifications) ---
NEYNAR_API_KEY=

# --- Onchain / token (only when a Capsule graduates to a coin; Clanker adapter) ---
# Base RPC + Clanker are v1.5+; leave blank for the milestone-1 Capsule foundation.
BASE_RPC_URL=
CLANKER_API_KEY=
