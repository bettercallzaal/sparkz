# Sparkz env - copy to .env.local and fill. NEVER commit real values.

# --- Supabase (the Capsule store) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only, never sent to the browser

# --- Cheap LLM tier (Meme Engine drafting - the 3 responses) ---
# Use OpenRouter/Ollama, not a metered Claude path (see CLAUDE.md).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# --- Farcaster (FEF - Farcaster Eats First; feed + identity + notifications) ---
NEYNAR_API_KEY=

# --- Onchain / token (only when a Capsule graduates to a coin; Clanker adapter) ---
# Base RPC + Clanker are v1.5+; leave blank for the milestone-1 Capsule foundation.
BASE_RPC_URL=
CLANKER_API_KEY=
