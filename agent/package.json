{
  "name": "sparkz-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous Meme Engine operator for a Sparkz Capsule - flag -> draft -> approve -> cast to Farcaster.",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "once": "AGENT_ONCE=true tsx src/index.ts",
    "test": "tsx --test src/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
